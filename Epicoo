-- LIMPAR
local function limpar()
	for _,v in pairs(scroll:GetChildren()) do
		if v:IsA("GuiObject") then v:Destroy() end
	end
end

-- ESTADOS (SALVOS)
local handAtivo = false
local armorAtivo = false
local aiAtivo = false
local tamanhoAI = 5
local autoExit = false

-- DAMAGE
local function atualizarTool()
	local model = workspace:FindFirstChild(player.Name)
	if not model then return end

	local hand2 = model:FindFirstChild("Hand2")
	if not hand2 then return end

	local toolName
	if hand2:IsA("ObjectValue") and hand2.Value then
		toolName = hand2.Value.Name
	elseif hand2:IsA("StringValue") then
		toolName = hand2.Value
	end

	if not toolName then return end

	local tool = player.Backpack:FindFirstChild(toolName) or (player.Character and player.Character:FindFirstChild(toolName))
	if tool then
		tool:SetAttribute("ChargeTime", 0.01)
	end
end

-- ARMOR
local function setarArmor()
	local model = workspace:FindFirstChild(player.Name)
	if model then
		local armor = model:FindFirstChild("ArmorPoints")
		if armor then armor.Value = 18 end
	end
end

-- AI
local function processarAI()
	for _,obj in pairs(workspace:GetChildren()) do
		if string.lower(obj.Name) == "ai" then
			for _,p in pairs(obj:GetDescendants()) do
				if p:IsA("BasePart") then
					p.Size = Vector3.new(tamanhoAI,tamanhoAI,tamanhoAI)
					p.Transparency = 0.8
					p.CanCollide = false
				end
			end
		end
	end
end

