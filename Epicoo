btnArmor.TextColor3 = Color3.new(1,1,1)
btnArmor.Font = Enum.Font.GothamBold
btnArmor.Parent = frame
aplicarCorner(btnArmor, 8)

-- estados
local handAtivo = false
local armorAtivo = false

-- funções
local function limparHand2()
    local model = workspace:FindFirstChild(player.Name)
    if model then
        local hand2 = model:FindFirstChild("Hand2")
        if hand2 and hand2:IsA("ObjectValue") then
            hand2.Value = nil
        end
    end
end

local function setarArmor()
    local model = workspace:FindFirstChild(player.Name)
    if model then
        local armor = model:FindFirstChild("ArmorPoints")
        if armor and armor:IsA("NumberValue") then
            armor.Value = 18
        end
    end
end

-- loop contínuo
task.spawn(function()
    while true do
        task.wait(0.3)
        if handAtivo then limparHand2() end
        if armorAtivo then setarArmor() end
    end
end)

-- toggles
btnHand.MouseButton1Click:Connect(function()
    handAtivo = not handAtivo
    btnHand.Text = "MORE DAMAGE " .. (handAtivo and "[ON]" or "[OFF]")
end)

btnArmor.MouseButton1Click:Connect(function()
    armorAtivo = not armorAtivo
    btnArmor.Text = "MORE ARMOR " .. (armorAtivo and "[ON]" or "[OFF]")
end)

-- animações
local function abrir()
    frame.Visible = true
    frame.Size = UDim2.new(0,0,0,0)
    TweenService:Create(frame, TweenInfo.new(0.25), {
        Size = UDim2.new(0,260,0,160)
    }):Play()
end

local function fechar()
    local t = TweenService:Create(frame, TweenInfo.new(0.25), {
        Size = UDim2.new(0,0,0,0)
    })
    t:Play()
    t.Completed:Wait()
    frame.Visible = false
end

-- controles
closeBtn.MouseButton1Click:Connect(function()
    fechar()
    openBtn.Visible = true
end)

openBtn.MouseButton1Click:Connect(function()
    abrir()
    openBtn.Visible = false
end)

-- recriar se apagar
player.CharacterAdded:Connect(function()
    task.wait(1)
    if not player.PlayerGui:FindFirstChild("EpicPainel") then
        local clone = script:Clone()
        clone.Parent = player.PlayerGui
    end
end)
