local function abrirHome()
	limpar()

	local b1 = btn("Damage "..(handAtivo and "[ON]" or "[OFF]"), Color3.fromRGB(200,60,60))
	local b2 = btn("Armor "..(armorAtivo and "[ON]" or "[OFF]"), Color3.fromRGB(60,120,255))
	local b3 = btn("Mace Damage "..(maceDmgAtivo and "[ON]" or "[OFF]"), Color3.fromRGB(255,140,40))

	b1.MouseButton1Click:Connect(function()
		handAtivo = not handAtivo
		b1.Text = "Damage "..(handAtivo and "[ON]" or "[OFF]")
	end)

	b2.MouseButton1Click:Connect(function()
		armorAtivo = not armorAtivo
		b2.Text = "Armor "..(armorAtivo and "[ON]" or "[OFF]")
	end)

	-- Slider de Jump Power
	local maceCfg = Instance.new("Frame")
	maceCfg.Size = UDim2.new(1,-10,0,70)
	maceCfg.Visible = maceDmgAtivo
	maceCfg.BackgroundColor3 = Color3.fromRGB(30,30,30)
	maceCfg.Parent = scroll
	corner(maceCfg,10)

	local maceLabel = Instance.new("TextLabel")
	maceLabel.Size = UDim2.new(1,0,0,22)
	maceLabel.Text = "Jump Power: "..JUMP_POWER
	maceLabel.BackgroundTransparency = 1
	maceLabel.TextColor3 = Color3.new(1,1,1)
	maceLabel.Font = Enum.Font.Gotham
	maceLabel.TextScaled = true
	maceLabel.Parent = maceCfg

	local maceBar = Instance.new("Frame")
	maceBar.Size = UDim2.new(0.9,0,0,10)
	maceBar.Position = UDim2.new(0.05,0,0.6,0)
	maceBar.BackgroundColor3 = Color3.fromRGB(80,80,80)
	maceBar.Parent = maceCfg
	corner(maceBar,5)

	local maceFill = Instance.new("Frame")
	maceFill.Size = UDim2.new((JUMP_POWER - 50) / 450, 0, 1, 0)
	maceFill.BackgroundColor3 = Color3.fromRGB(255,140,40)
	maceFill.Parent = maceBar
	corner(maceFill,5)

	local function updateJump(x)
		local pct = math.clamp((x - maceBar.AbsolutePosition.X) / maceBar.AbsoluteSize.X, 0, 1)
		maceFill.Size = UDim2.new(pct, 0, 1, 0)
		JUMP_POWER = math.clamp(math.floor(50 + pct * 450), 50, 500)
		maceLabel.Text = "Jump Power: "..JUMP_POWER
	end

	maceBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			updateJump(input.Position.X)
			local move, release
			move = UIS.InputChanged:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
					updateJump(i.Position.X)
				end
			end)
			release = UIS.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					move:Disconnect()
					release:Disconnect()
				end
			end)
		end
	end)

	b3.MouseButton1Click:Connect(function()
		maceDmgAtivo = not maceDmgAtivo
		b3.BackgroundColor3 = maceDmgAtivo and Color3.fromRGB(255,100,0) or Color3.fromRGB(255,140,40)
		b3.Text = "Mace Damage "..(maceDmgAtivo and "[ON]" or "[OFF]")
		maceCfg.Visible = maceDmgAtivo
		if not maceDmgAtivo then
			local char = player.Character
			if char then
				local hum = char:FindFirstChild("Humanoid")
				if hum then hum.JumpPower = 50 end
			end
		end
	end)

	local aiBtn = btn("AUTO AI "..(aiAtivo and "[ON]" or "[OFF]"), Color3.fromRGB(150,60,255), 40)

	local config = Instance.new("Frame")
	config.Size = UDim2.new(1,-10,0,70)
	config.Visible = aiAtivo
	config.BackgroundColor3 = Color3.fromRGB(30,30,30)
	config.Parent = scroll
	corner(config,10)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1,0,0,20)
	label.Text = "Size: "..tamanhoAI
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.new(1,1,1)
	label.Parent = config

	local bar = Instance.new("Frame")
	bar.Size = UDim2.new(0.9,0,0,10)
	bar.Position = UDim2.new(0.05,0,0.6,0)
	bar.BackgroundColor3 = Color3.fromRGB(80,80,80)
	bar.Parent = config
	corner(bar,5)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new(tamanhoAI/20,0,1,0)
	fill.BackgroundColor3 = Color3.fromRGB(150,60,255)
	fill.Parent = bar
	corner(fill,5)

	local function update(x)
		local pct = math.clamp((x - bar.AbsolutePosition.X)/bar.AbsoluteSize.X,0,1)
		fill.Size = UDim2.new(pct,0,1,0)
		tamanhoAI = math.clamp(math.floor(pct*20),1,20)
		label.Text = "Size: "..tamanhoAI
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			update(input.Position.X)
			local move, release
			move = UIS.InputChanged:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
					update(i.Position.X)
				end
			end)
			release = UIS.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					move:Disconnect()
					release:Disconnect()
				end
			end)
		end
	end)

	aiBtn.MouseButton1Click:Connect(function()
		aiAtivo = not aiAtivo
		config.Visible = aiAtivo
		aiBtn.Text = "AUTO AI "..(aiAtivo and "[ON]" or "[OFF]")
	end)
end

