-- HOME
local function abrirHome()
	limpar()

	local b1 = btn("Damage "..(handAtivo and "[ON]" or "[OFF]"), Color3.fromRGB(200,60,60))
	local b2 = btn("Armor "..(armorAtivo and "[ON]" or "[OFF]"), Color3.fromRGB(60,120,255))

	b1.MouseButton1Click:Connect(function()
		handAtivo = not handAtivo
		b1.Text = "Damage "..(handAtivo and "[ON]" or "[OFF]")
	end)

	b2.MouseButton1Click:Connect(function()
		armorAtivo = not armorAtivo
		b2.Text = "Armor "..(armorAtivo and "[ON]" or "[OFF]")
	end)

	-- AUTO AI
	local aiBtn = btn("AUTO AI "..(aiAtivo and "[ON]" or "[OFF]"), Color3.fromRGB(150,60,255), 40)

	local config = Instance.new("Frame")
	config.Size = UDim2.new(1,-10,0,70)
	config.Visible = aiAtivo
	config.BackgroundColor3 = Color3.fromRGB(30,30,30)
	config.Parent = scroll
	corner(config,10)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1,0,0,20)
	label.Text = "Size: "..tamanhoAI
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.new(1,1,1)
	label.Parent = config

	local bar = Instance.new("Frame")
	bar.Size = UDim2.new(0.9,0,0,10)
	bar.Position = UDim2.new(0.05,0,0.6,0)
	bar.BackgroundColor3 = Color3.fromRGB(80,80,80)
	bar.Parent = config
	corner(bar,5)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new(tamanhoAI/20,0,1,0)
	fill.BackgroundColor3 = Color3.fromRGB(150,60,255)
	fill.Parent = bar
	corner(fill,5)

	-- SLIDER FIXO
	local function update(x)
		local pct = math.clamp((x - bar.AbsolutePosition.X)/bar.AbsoluteSize.X,0,1)
		fill.Size = UDim2.new(pct,0,1,0)
		tamanhoAI = math.clamp(math.floor(pct*20),1,20)
		label.Text = "Size: "..tamanhoAI
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			update(input.Position.X)

			local move, release
			move = UIS.InputChanged:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
					update(i.Position.X)
				end
			end)

			release = UIS.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					move:Disconnect()
					release:Disconnect()
				end
			end)
		end
	end)

	aiBtn.MouseButton1Click:Connect(function()
		aiAtivo = not aiAtivo
		config.Visible = aiAtivo
		aiBtn.Text = "AUTO AI "..(aiAtivo and "[ON]" or "[OFF]")
	end)
end

-- SECURITY
local function abrirSecurity()
	limpar()

	local b = btn("AUTO EXIT "..(autoExit and "[ON]" or "[OFF]"), Color3.fromRGB(255,200,0), 35)

	b.MouseButton1Click:Connect(function()
		autoExit = not autoExit
		b.Text = "AUTO EXIT "..(autoExit and "[ON]" or "[OFF]")
	end)
end

-- LOOP
task.spawn(function()
	while true do
		task.wait(0.3)

		if handAtivo then atualizarTool() end
		if armorAtivo then setarArmor() end
		if aiAtivo then processarAI() end

		if autoExit and Players:FindFirstChild("KeqingBurst") then
			player:Kick("Auto Exit")
		end
	end
end)

homeTab.MouseButton1Click:Connect(abrirHome)
secTab.MouseButton1Click:Connect(abrirSecurity)

