-- botão MORE ARMOR
local btnArmor = Instance.new("TextButton")
btnArmor.Size = UDim2.new(0.8, 0, 0, 40)
btnArmor.Position = UDim2.new(0.1, 0, 0.65, 0)
btnArmor.Text = "MORE ARMOR [OFF]"
btnArmor.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
