		corner(b,8)

		b.MouseButton1Click:Connect(function()
			item.ativo = not item.ativo
			b.Text = (item.ativo and "✓ " or "✗ ") .. item.name
			b.BackgroundColor3 = item.ativo and Color3.fromRGB(25,50,25) or Color3.fromRGB(50,25,25)
			b.TextColor3 = item.ativo and item.cor or Color3.fromRGB(110,110,110)
		end)

		table.insert(itemBtns, {b=b, item=item})
	end

