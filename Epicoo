-- LOOP PRINCIPAL
-- ============================
task.spawn(function()
	while true do
		task.wait(0.3)
		if handAtivo  then atualizarTool() end
		if armorAtivo then setarArmor()    end
		if aiAtivo    then processarAI()   end
		if espAtivo   then processarESP()  end
		if maceDmgAtivo then
			local char = player.Character
			if char then
				local hum = char:FindFirstChild("Humanoid")
				if hum then
					hum.UseJumpPower = true
					hum.JumpPower = JUMP_POWER
				end
			end
		end
		if autoExit and Players:FindFirstChild("KeqingBurst") then
			player:Kick("Auto Exit")
		end
	end
end)

