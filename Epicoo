-- ============================
-- MACE DAMAGE (JUMP BOOST)
-- ============================
local JUMP_POWER   = 100  -- controlado pelo slider (50~500)
local JUMP_ANIM_ID = "rbxassetid://507765000"

local function configurarJumpAnim(character)
	local humanoid = character:WaitForChild("Humanoid")
	local animator = humanoid:WaitForChild("Animator")

	humanoid.StateChanged:Connect(function(_, newState)
		if newState == Enum.HumanoidStateType.Jumping or newState == Enum.HumanoidStateType.Freefall then
			if maceDmgAtivo then
				-- Velocidade proporcional ao JUMP_POWER pra parecer visual normal
				local speed = math.clamp(JUMP_POWER / 50, 1, 12)
				for _, track in pairs(animator:GetPlayingAnimationTracks()) do
					track:AdjustSpeed(speed)
				end
			end
		elseif newState == Enum.HumanoidStateType.Landed or newState == Enum.HumanoidStateType.Running then
			-- Reseta velocidade ao pousar
			for _, track in pairs(animator:GetPlayingAnimationTracks()) do
				track:AdjustSpeed(1)
			end
		end
	end)
end

if player.Character then
	configurarJumpAnim(player.Character)
end
player.CharacterAdded:Connect(configurarJumpAnim)

